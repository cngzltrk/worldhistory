---
const categories = [
  {
    title: "Dünya Tarihi",
    description: "MÖ 3500'den bugüne insanlığın ortak hikayesi",
    href: "/dunya-tarihi",
    available: true,
  },
  {
    title: "Din Tarihi",
    description: "İnançların, ritüellerin ve kutsal metinlerin evrimi",
    href: "/din-tarihi",
    available: false,
  },
  {
    title: "Ekonomik Tarih",
    description: "Ticaret yolları, para sistemleri ve ekonomik devrimler",
    href: "/ekonomik-tarih",
    available: false,
  },
  {
    title: "Amerika Tarihi",
    description: "Kıtanın keşfinden günümüz ABD'sine uzanan süreç",
    href: "/amerika-tarihi",
    available: false,
  },
  {
    title: "Türkiye Tarihi",
    description: "Anadolu uygarlıklarından Cumhuriyet'e",
    href: "/turkiye-tarihi",
    available: false,
  },
  {
    title: "Kürt Tarihi",
    description: "Kadim Kürt halklarının kültürü, coğrafyası ve tarihi",
    href: "/kurt-tarihi",
    available: false,
  },
];
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tarih Atlası</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:       #0b0905;
        --surface:  #161209;
        --surface2: #1e1810;
        --border:   #4a3d24;
        --gold:     #c8922a;
        --gold-dim: #7a5818;
        --glow:     rgba(200, 146, 42, 0.15);
        --text:     #e6d9bc;
        --muted:    #7a6d55;
      }

      body {
        background-color: var(--bg);
        background-image:
          radial-gradient(ellipse 80% 50% at 50% 10%, rgba(60, 40, 10, 0.5) 0%, transparent 70%),
          radial-gradient(ellipse 50% 40% at 50% 90%, rgba(40, 25, 5, 0.3) 0%, transparent 70%);
        color: var(--text);
        font-family: Georgia, "Times New Roman", serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem 1.5rem;
      }

      /* ── Header ───────────────────────────────────── */
      .page-header {
        text-align: center;
        margin-bottom: 4rem;
      }

      .header-ornament {
        display: block;
        font-size: 0.9rem;
        color: var(--gold-dim);
        letter-spacing: 0.6em;
        margin-bottom: 1rem;
        user-select: none;
      }

      h1 {
        font-size: clamp(2rem, 5vw, 3.4rem);
        font-weight: 400;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--gold);
        text-shadow: 0 0 50px rgba(200, 146, 42, 0.25);
      }

      .header-rule {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        margin: 1rem auto 0.8rem;
        color: var(--gold-dim);
        font-size: 0.75rem;
        letter-spacing: 0.3em;
      }
      .header-rule::before,
      .header-rule::after {
        content: "";
        display: block;
        width: 60px;
        height: 1px;
      }
      .header-rule::before { background: linear-gradient(to right, transparent, var(--gold-dim)); }
      .header-rule::after  { background: linear-gradient(to left,  transparent, var(--gold-dim)); }

      .page-header p {
        color: var(--muted);
        font-size: 0.82rem;
        font-style: italic;
        letter-spacing: 0.05em;
      }

      /* ── Grid ─────────────────────────────────────── */
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.1rem;
        width: 100%;
        max-width: 820px;
      }

      /* ── Category card ────────────────────────────── */
      .card {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-top: 2px solid var(--gold-dim);
        padding: 1.4rem 1.4rem 1.3rem;
        text-decoration: none;
        color: inherit;
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s, transform 0.18s;
      }

      .card::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.02) 0%, transparent 60%);
        pointer-events: none;
      }

      .card.available:hover,
      .card.available:focus-visible {
        border-color: var(--gold);
        border-top-color: var(--gold);
        background: var(--surface2);
        box-shadow: 0 0 28px var(--glow), 0 4px 20px rgba(0,0,0,0.5);
        transform: translateY(-2px);
        outline: none;
      }

      .card.soon {
        opacity: 0.45;
        cursor: default;
        pointer-events: none;
      }

      .card-title {
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        color: var(--text);
        transition: color 0.2s;
      }
      .card.available:hover .card-title { color: var(--gold); }

      .card-desc {
        font-size: 0.78rem;
        color: var(--muted);
        line-height: 1.55;
        font-style: italic;
      }

      .card-badge {
        margin-top: 0.4rem;
        font-size: 0.65rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--gold-dim);
      }
      .card.available .card-badge { color: var(--gold); }
    </style>
  </head>
  <body>
    <header class="page-header">
      <span class="header-ornament">✦ &nbsp; ✦ &nbsp; ✦</span>
      <h1>Tarih Atlası</h1>
      <div class="header-rule">Bir kategori seçin</div>
      <p>Keşfetmek istediğiniz tarih dalını seçin</p>
    </header>

    <main>
      <div class="grid">
        {categories.map((cat) => (
          cat.available
            ? <a href={cat.href} class="card available">
                <div class="card-title">{cat.title}</div>
                <div class="card-desc">{cat.description}</div>
                <div class="card-badge">Keşfet &rsaquo;</div>
              </a>
            : <div class="card soon">
                <div class="card-title">{cat.title}</div>
                <div class="card-desc">{cat.description}</div>
                <div class="card-badge">Yakında</div>
              </div>
        ))}
      </div>
    </main>
  </body>
</html>
